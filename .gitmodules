[submodule "Hedron/vendor/spdlog"]
	path = Hedron/vendor/spdlog
	url = https://github.com/gabime/spdlog
[submodule "Hedron/vendor/GLFW"]
	path = Hedron/vendor/GLFW
	url = https://github.com/TheCherno/GLFW
	ignore = dirty
[submodule "Hedron/vendor/imgui"]
	path = Hedron/vendor/imgui
	url = https://github.com/TheCherno/imgui
	ignore = dirty
[submodule "Hedron/vendor/glm"]
	path = Hedron/vendor/glm
	url = https://github.com/g-truc/glm
